{
  "version": 2,
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.6.2"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/about", "dest": "/about.php" },
    { "src": "/opportunities", "dest": "/opportunities.php" },
    { "src": "/admissions", "dest": "/admissions.php" },
    { "src": "/contact", "dest": "/contact.php" },
    { "src": "/", "dest": "/index.php" }
  ]
}
